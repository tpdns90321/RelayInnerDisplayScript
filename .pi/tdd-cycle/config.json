{
  "configVersion": 1,
  "confirmed": true,
  "testWriteGlobs": [
    "tests/**"
  ],
  "greenAllowedTestArtifactGlobs": [],
  "refactorAllowedTestFiles": [],
  "coverage": {
    "enabled": true,
    "command": "mkdir -p coverage && coverage run --data-file=coverage/.coverage --source=relayinner_display -m unittest discover -s tests -p 'test_*.py' && coverage json --data-file=coverage/.coverage -o coverage/coverage-summary.json",
    "summaryFile": "coverage/coverage-summary.json",
    "metrics": [
      "totals.percent_covered"
    ],
    "outputGlobs": [
      "coverage/**"
    ]
  },
  "testOutputGlobs": [
    "tmp/test-output/**"
  ],
  "network": {
    "allowedDomains": [],
    "deniedDomains": []
  },
  "denyReadGlobs": [
    ".env",
    ".env.*",
    "**/*.pem",
    "**/*.key",
    "**/id_rsa",
    "**/id_ed25519"
  ],
  "timeouts": {
    "redSeconds": 1800,
    "greenSeconds": 1800,
    "refactorSeconds": 1800,
    "coverageSeconds": 600
  }
}
